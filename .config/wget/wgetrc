# 
# ~/.config/wget/wgetrc
# 

recursive = on
timestamping = on
reclevel = 8
dirstruct = on
continue = on
convert_links = on
backup_converted = on
adjust_extension = on
#span_hosts = on
no_parent = on
logfile = ~/.local/share/wget.log
keep_session_cookies = on
save_cookies = ~/.local/state/wget.cookies
