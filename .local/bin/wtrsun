#!/bin/sh
#wtrsun
# show uv-index and chance of high-temp
# also, show sun-hours and max temp for the day

hour="$(/usr/bin/date '+%H')"
wfile="$HOME/.local/share/weather.txt"

# exit if wfile not present or empty
if [ -z "$wfile" ]; then
    exit 1
fi

# check if wfile updated for the day, then return daily total sun-hours and maximum temperature
if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
    sunhour="$(/usr/bin/jq -r '.weather[0].sunHour' "$wfile")"
    maxtemp="$(/usr/bin/jq -r '.weather[0].maxtempC' "$wfile")"
else
    sunhour="$(/usr/bin/jq -r '.weather[1].sunHour' "$wfile")"
    maxtemp="$(/usr/bin/jq -r '.weather[1].maxtempC' "$wfile")"
fi

# check if wfile updated for the day, then return hourly uv-index and hourly chance of high temperature
if [ "$hour" -ge 0 ] && [ "$hour" -lt 3 ]; then
    if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[0].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[0].hourly[0].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[0].hourly[0].chanceofhightemp' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[0].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[1].hourly[0].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[1].hourly[0].chanceofhightemp' "$wfile")"
    fi
elif [ "$hour" -ge 3 ] && [ "$hour" -lt 6 ]; then
    if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[1].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[0].hourly[1].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[0].hourly[1].chanceofhightemp' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[1].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[1].hourly[1].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[1].hourly[1].chanceofhightemp' "$wfile")"
    fi
elif [ "$hour" -ge 6 ] && [ "$hour" -lt 9 ]; then
    if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[2].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[0].hourly[2].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[0].hourly[2].chanceofhightemp' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[2].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[1].hourly[2].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[1].hourly[2].chanceofhightemp' "$wfile")"
    fi
elif [ "$hour" -ge 9 ] && [ "$hour" -lt 12 ]; then
    if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[3].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[0].hourly[3].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[0].hourly[3].chanceofhightemp' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[3].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[1].hourly[3].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[1].hourly[3].chanceofhightemp' "$wfile")"
    fi
elif [ "$hour" -ge 12 ] && [ "$hour" -lt 15 ]; then
    if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[4].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[0].hourly[4].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[0].hourly[4].chanceofhightemp' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[4].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[1].hourly[4].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[1].hourly[4].chanceofhightemp' "$wfile")"
    fi
elif [ "$hour" -ge 15 ] && [ "$hour" -lt 18 ]; then
    if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[5].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[0].hourly[5].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[0].hourly[5].chanceofhightemp' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[5].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[1].hourly[5].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[1].hourly[5].chanceofhightemp' "$wfile")"
    fi
elif [ "$hour" -ge 18 ] && [ "$hour" -lt 21 ]; then
    if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[6].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[0].hourly[6].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[0].hourly[6].chanceofhightemp' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[6].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[1].hourly[6].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[1].hourly[6].chanceofhightemp' "$wfile")"
    fi
else
    if [ "$(/usr/bin/jq -r '.weather[0].date' "$wfile" | /usr/bin/tr -d '-')" -eq "$(/usr/bin/date '+%Y%m%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[7].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[0].hourly[7].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[0].hourly[7].chanceofhightemp' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[7].weatherDesc[0].value' "$wfile")"
        uvindex="$(/usr/bin/jq -r '.weather[1].hourly[7].uvIndex' "$wfile")"
        hightemp="$(/usr/bin/jq -r '.weather[1].hourly[7].chanceofhightemp' "$wfile")"
    fi
fi

# uv-index
if [ "$uvindex" -le 2 ]; then
    uvwarning="low"
elif [ "$uvindex" -ge 3 ] && [ "$uvindex" -le 5 ]; then
    uvwarning="moderate"
elif [ "$uvindex" -ge 6 ] && [ "$uvindex" -le 7 ]; then
    uvwarning="high"
elif [ "$uvindex" -ge 8 ] && [ "$uvindex" -le 10 ]; then
    uvwarning="very high"
else
    uvwarning="extreme"
fi

/usr/bin/printf "%s\n" "$desc conditions with $uvwarning UV-warning for UV-index of $uvindex. Maximum temperature for today is $maxtemp°C, chances of touching it now is $hightemp%. Total solar insolation for the day, from dawn till dusk, is $sunhour hrs."
