#!/bin/sh
#ccc
# curl URL to desired output
# if using URL, yank to primary clipboard

# check clipboard or for a '*.url' named file in directory, before continuing
# check if file is empty or if URL link is valid, before continuing
# if URL only named 'readme', change output to name of parent directory

# if [ -z "$(/usr/bin/xclip -o)" ]; then
