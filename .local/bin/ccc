# elif /usr/bin/printf "%s" "$(/usr/bin/xclip -o)" | /usr/bin/grep -Eiq 'http[s]://[^ ]+'; then
#         /usr/bin/notify-send -u low "valid URL link found"
#         projdir="$(/usr/bin/pwd | /usr/bin/sed 's@.*/@@')"
#         projurl="$(/usr/bin/printf "%s" "$(/usr/bin/xclip -o)" | \
#             /usr/bin/xargs /usr/bin/basename | /usr/bin/sed 's@\..*$@@')"
