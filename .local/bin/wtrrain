#!/bin/sh
#wtrrain
# show hourly rain chance and precipitation in mm
# also, show chance of thunder and cloud cover

hour="$(/usr/bin/date '+%H')"
wfile="$HOME/.local/share/weather.txt"

# exit if wfile not present or empty
if [ -z "$wfile" ]; then
    exit 1
fi

# check if wfile updated for the day, then proceed accordingly
if [ "$hour" -ge 0 ] && [ "$hour" -lt 3 ]; then
    if [ "$(/usr/bin/stat -c %y "$wfile" | /usr/bin/cut -d ' ' -f1)" = "$(/usr/bin/date '+%Y-%m-%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[0].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[0].hourly[0].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[0].hourly[0].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[0].hourly[0].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[0].hourly[0].cloudcover' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[0].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[1].hourly[0].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[1].hourly[0].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[1].hourly[0].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[1].hourly[0].cloudcover' "$wfile")"
    fi
elif [ "$hour" -ge 3 ] && [ "$hour" -lt 6 ]; then
    if [ "$(/usr/bin/stat -c %y "$wfile" | /usr/bin/cut -d ' ' -f1)" = "$(/usr/bin/date '+%Y-%m-%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[1].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[0].hourly[1].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[0].hourly[1].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[0].hourly[1].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[0].hourly[1].cloudcover' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[1].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[1].hourly[1].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[1].hourly[1].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[1].hourly[1].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[1].hourly[1].cloudcover' "$wfile")"
    fi
elif [ "$hour" -ge 6 ] && [ "$hour" -lt 9 ]; then
    if [ "$(/usr/bin/stat -c %y "$wfile" | /usr/bin/cut -d ' ' -f1)" = "$(/usr/bin/date '+%Y-%m-%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[2].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[0].hourly[2].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[0].hourly[2].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[0].hourly[2].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[0].hourly[2].cloudcover' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[2].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[1].hourly[2].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[1].hourly[2].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[1].hourly[2].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[1].hourly[2].cloudcover' "$wfile")"
    fi
elif [ "$hour" -ge 9 ] && [ "$hour" -lt 12 ]; then
    if [ "$(/usr/bin/stat -c %y "$wfile" | /usr/bin/cut -d ' ' -f1)" = "$(/usr/bin/date '+%Y-%m-%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[3].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[0].hourly[3].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[0].hourly[3].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[0].hourly[3].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[0].hourly[3].cloudcover' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[3].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[1].hourly[3].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[1].hourly[3].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[1].hourly[3].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[1].hourly[3].cloudcover' "$wfile")"
    fi
elif [ "$hour" -ge 12 ] && [ "$hour" -lt 15 ]; then
    if [ "$(/usr/bin/stat -c %y "$wfile" | /usr/bin/cut -d ' ' -f1)" = "$(/usr/bin/date '+%Y-%m-%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[4].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[0].hourly[4].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[0].hourly[4].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[0].hourly[4].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[0].hourly[4].cloudcover' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[4].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[1].hourly[4].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[1].hourly[4].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[1].hourly[4].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[1].hourly[4].cloudcover' "$wfile")"
    fi
elif [ "$hour" -ge 15 ] && [ "$hour" -lt 18 ]; then
    if [ "$(/usr/bin/stat -c %y "$wfile" | /usr/bin/cut -d ' ' -f1)" = "$(/usr/bin/date '+%Y-%m-%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[5].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[0].hourly[5].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[0].hourly[5].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[0].hourly[5].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[0].hourly[5].cloudcover' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[5].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[1].hourly[5].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[1].hourly[5].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[1].hourly[5].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[1].hourly[5].cloudcover' "$wfile")"
    fi
elif [ "$hour" -ge 18 ] && [ "$hour" -lt 21 ]; then
    if [ "$(/usr/bin/stat -c %y "$wfile" | /usr/bin/cut -d ' ' -f1)" = "$(/usr/bin/date '+%Y-%m-%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[6].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[0].hourly[6].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[0].hourly[6].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[0].hourly[6].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[0].hourly[6].cloudcover' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[6].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[1].hourly[6].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[1].hourly[6].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[1].hourly[6].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[1].hourly[6].cloudcover' "$wfile")"
    fi
else
    if [ "$(/usr/bin/stat -c %y "$wfile" | /usr/bin/cut -d ' ' -f1)" = "$(/usr/bin/date '+%Y-%m-%d')" ]; then
        desc="$(/usr/bin/jq -r '.weather[0].hourly[7].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[0].hourly[7].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[0].hourly[7].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[0].hourly[7].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[0].hourly[7].cloudcover' "$wfile")"
    else
        desc="$(/usr/bin/jq -r '.weather[1].hourly[7].weatherDesc[0].value' "$wfile")"
        rainchance="$(/usr/bin/jq -r '.weather[1].hourly[7].chanceofrain' "$wfile")"
        rainmm="$(/usr/bin/jq -r '.weather[1].hourly[7].precipMM' "$wfile")"
        thunderchance="$(/usr/bin/jq -r '.weather[1].hourly[7].chanceofthunder' "$wfile")"
        cloudcover="$(/usr/bin/jq -r '.weather[1].hourly[7].cloudcover' "$wfile")"
    fi
fi

/usr/bin/printf "%s\n" "$desc conditions with $rainchance% chance and $rainmm mm of rain. Cloud cover to be at $cloudcover%, with chances of thunder at $thunderchance%."
