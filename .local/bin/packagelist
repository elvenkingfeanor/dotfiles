#!/bin/sh
#packagelist
# return list of explicitly installed packages and groups associated with user
# for weekly cron

# user groups
/usr/bin/id 1000 > ~/.bak/userinfo/groups.txt
# official (native) packages
/usr/bin/pacman -Qqent > ~/.bak/userinfo/pacman.lst
# AUR (foreign) packages
/usr/bin/pacman -Qqemt > ~/.bak/userinfo/aur.lst
# package check
/usr/bin/pacman -Qk > ~/.bak/userinfo/package-check.txt

/usr/bin/notify-send "package list generated"
